PORT=3000
# HTTP API: глобальный префикс /api (GET / без префикса). Фронт: baseURL http://localhost:3000/api
# Сидеры (после migration:run):
#   npm run seed:catalog
#   npm run seed:skill-tests
#   npm run seed:bootstrap  — ADMIN + HH system employer (см. BOOTSTRAP_* ниже)
# CORS: фронт на другом origin (через запятую). Пусто = разрешить любой origin (удобно для dev).
# Пример: CORS_ORIGIN=http://localhost:5173
CORS_ORIGIN=
NODE_ENV=development
# Совпадает с docker-compose.yml (postgres / postgres, БД sjs, порт 5432)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sjs
TYPEORM_LOGGING=false
# В production выключите synchronize и применяйте миграции: npm run migration:run (нужен DATABASE_URL)

JWT_SECRET=change-me-in-production-min-32-chars-long
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_DAYS=30

REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO / S3-совместимое API для presigned upload
# Локально: docker compose up -d minio (API :9000, консоль :9001, логин/пароль как S3_ACCESS_KEY / S3_SECRET_KEY)
S3_ENDPOINT=http://localhost:9000
# Опционально: URL для presigned PUT, видимый из браузера (если отличается от S3_ENDPOINT).
# Пример: бэкенд в Docker с S3_ENDPOINT=http://minio:9000 → S3_PRESIGN_ENDPOINT=http://localhost:9000
# S3_PRESIGN_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=sjs
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123

# OpenAI: парсинг расписания из PDF/изображения (воркер ai-parse-schedule). Без ключа — заглушка-слоты.
OPENAI_API_KEY=
OPENAI_SCHEDULE_MODEL=gpt-4o-mini
# Chat completions: cover letter, resume suggestions, interview prep
OPENAI_CHAT_MODEL=gpt-4o-mini
# Эмбеддинги (очередь ai-embeddings) и скоринг откликов (ai-score-application)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Telegram Bot API
# TELEGRAM_BOT_USERNAME — имя бота без @ (для deep-link POST /api/telegram/link-token)
# TELEGRAM_WEBHOOK_SECRET — secret_token при setWebhook → POST /api/telegram/webhook
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# SMTP (Nodemailer): дублирует in-app уведомления на email пользователя
# Без этих переменных email-уведомления отключены (см. EmailService)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# Импорт вакансий с HH (api.hh.ru). Cron каждые 6 ч только при HH_IMPORT_ENABLED=true
# HH_SYSTEM_EMPLOYER_USER_ID — UUID пользователя с ролью EMPLOYER и заполненным employer profile (витрина для импорта)
HH_IMPORT_ENABLED=false
HH_SYSTEM_EMPLOYER_USER_ID=
HH_API_USER_AGENT="SJS-Back/1.0 (you@example.com)"
# OAuth приложения HH (обязательно для GET /vacancies с 2024+): https://dev.hh.ru/admin
# Вариант 1 — скопировать access_token из админки приложения:
# HH_APP_ACCESS_TOKEN=
# Вариант 2 — client_credentials (токен запрашивается автоматически):
# HH_APP_CLIENT_ID=
# HH_APP_CLIENT_SECRET=
# Ручной запуск (ADMIN): POST /api/admin/hh-import?text=стажировка&area=160 (160 = Алматы, 40 = Казахстан)

# Daily.co (видеоинтервью): POST /api/video/rooms/:applicationId
# Без ключа — возвращает demo URL
DAILY_API_KEY=

# Twilio SMS: при смене статуса заявки и Job Alerts
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Kaspi Pay: Premium-размещение вакансии
# Зарегистрируйтесь как мерчант на kaspi.kz/bank/developer
# KASPI_PREMIUM_PRICE_KZT — цена в тенге (по умолчанию 9900)
KASPI_MERCHANT_ID=
KASPI_API_KEY=
KASPI_PREMIUM_PRICE_KZT=9900
KASPI_RETURN_URL=https://sjs.app/employer/jobs
KASPI_WEBHOOK_SECRET=

# Bootstrap: npm run seed:bootstrap (создаёт ADMIN и HH employer, выводит UUID для .env)
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_HH_EMPLOYER_EMAIL=
BOOTSTRAP_HH_EMPLOYER_PASSWORD=
BOOTSTRAP_HH_EMPLOYER_COMPANY=SJS HH Import

# E2E admin tests (optional): npm run test:e2e с существующим admin после seed:bootstrap
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=

# GitHub API (Спринт 3: публичный профиль с репозиториями)
# Без токена работает с rate-limit 60 req/hour. С токеном — 5000 req/hour.
GITHUB_TOKEN=
